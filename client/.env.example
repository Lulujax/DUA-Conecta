# ============================================================
# VARIABLES DE ENTORNO DEL FRONTEND (client/.env)
# Copia este archivo a client/.env y rellena los valores.
# En Vercel: añade estas variables en "Settings" > "Environment Variables"
# IMPORTANTE: Las variables VITE_* se incrustan en el bundle en tiempo de build.
# ============================================================

# --- URL BASE DE LA API (backend) ---
# En desarrollo local apunta a tu servidor local:
# VITE_API_URL=http://localhost:3000
#
# En producción apunta a tu servicio de Render:
# VITE_API_URL=https://tu-backend.onrender.com
