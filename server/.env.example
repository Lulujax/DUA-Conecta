DATABASE_URL=postgresql://user:password@host:port/dbname

JWT_SECRET=change_this_to_a_long_random_secret

PIXABAY_API_KEY=your_pixabay_api_key_here

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password

PEXELS_API_KEY=your_pexels_api_key_here

# ⚠️  OBLIGATORIO en producción: URL pública del frontend en Vercel.
# Sin esta variable el CORS bloqueará todas las peticiones desde el frontend desplegado.
# Ejemplo: FRONTEND_URL=https://dua-conecta.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Opcional: lista separada por comas de orígenes extra permitidos (previews de Vercel, staging, etc.)
# ADDITIONAL_ORIGINS=https://dua-conecta-preview.vercel.app,https://staging.example.com