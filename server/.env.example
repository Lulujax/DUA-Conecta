# ============================================================
# VARIABLES DE ENTORNO DEL BACKEND (server/.env)
# Copia este archivo a server/.env y rellena los valores.
# En Render: añade estas variables en "Environment" > "Add Env Var"
# ============================================================

# --- BASE DE DATOS (Supabase / PostgreSQL) ---
DATABASE_URL="postgresql://usuario:contraseña@host:puerto/nombre_db"

# Pon DATABASE_SSL=false solo si usas una DB local sin SSL
# DATABASE_SSL=false

# --- SEGURIDAD ---
# Genera un secreto largo y aleatorio, ej: openssl rand -hex 32
JWT_SECRET="cambia_esto_por_un_secreto_seguro_y_largo"

# --- CORS / FRONTEND ---
# URL pública del frontend en producción (tu dominio de Vercel).
# Ejemplo: https://dua-conecta.vercel.app
# Para desarrollo local el valor por defecto es http://localhost:5173
FRONTEND_URL="https://dua-conecta.vercel.app"

# Si necesitas permitir múltiples orígenes sepáralos con comas:
# CORS_ORIGIN="https://tu-proyecto.vercel.app,https://otro-dominio.com"

# --- PUERTO (Render lo inyecta automáticamente) ---
# PORT=3000

# --- IMÁGENES (Pixabay) ---
PIXABAY_API_KEY="tu_api_key_de_pixabay"

# --- CORREO (Resend — https://resend.com) ---
RESEND_API_KEY="re_tu_api_key_de_resend"
EMAIL_FROM="DUA Conecta <noreply@tudominio.com>"

# --- CORREO (SMTP alternativo) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tuemail@gmail.com
# SMTP_PASS=tu_contraseña_de_aplicacion
