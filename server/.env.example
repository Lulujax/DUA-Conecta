DATABASE_URL=postgresql://user:password@host:port/dbname

JWT_SECRET=change_this_to_a_long_random_secret

PIXABAY_API_KEY=your_pixabay_api_key_here

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password

PEXELS_API_KEY=your_pexels_api_key_here

# Primary frontend URL (e.g. your Vercel production URL)
FRONTEND_URL=https://your-frontend.vercel.app

# Optional: comma-separated list of extra allowed origins (Vercel preview URLs, staging, etc.)
# ADDITIONAL_ORIGINS=https://dua-conecta-preview.vercel.app,https://staging.example.com